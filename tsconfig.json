{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "./dist",
    "lib": ["ES2020"],
    "types": ["node", "vscode"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "extension.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}