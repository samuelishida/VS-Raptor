{
	"name": "raptor",
	"displayName": "Raptor",
	"version": "0.2.0",
	"description": "Deterministic agent orchestration for skills, specialist agents, and custom flows. Works as a VS Code extension, Claude Code plugin, and skill pack for Codex CLI / OpenCode / any tool that accepts a system prompt.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/samuelishida/raptor.git"
	},
	"homepage": "https://github.com/samuelishida/raptor#readme",
	"bugs": {
		"url": "https://github.com/samuelishida/raptor/issues"
	},
	"keywords": [
		"agent",
		"orchestrator",
		"workflow",
		"skills",
		"audit",
		"review",
		"planning",
		"claude",
		"codex",
		"opencode"
	],
	"files": [
		".claude-plugin/",
		"skills/",
		"agents/",
		"install.sh",
		"uninstall.sh",
		"plugin.json",
		"README.md"
	],
	"bin": {
		"raptor-install": "./install.sh",
		"raptor-uninstall": "./uninstall.sh"
	},
	"categories": [
		"Other",
		"AI"
	],
	"main": "./dist/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch --p \"./\"",
		"install:skills": "./install.sh",
		"setup": "npm run compile && chmod +x install.sh uninstall.sh",
		"validate:inventory": "node ./scripts/validate-inventory.mjs",
		"smoke:orchestration": "node ./scripts/smoke-orchestration.mjs"
	},
	"devDependencies": {
		"@types/node": "^20",
		"@types/vscode": "^1.8.0",
		"typescript": "^5.0.0"
	},
	"engines": {
		"vscode": "^1.102.0"
	},
	"publisher": "samuelishida",
	"activationEvents": [
		"onChatParticipant:raptor",
		"onCommand:raptor.openPanel"
	],
	"contributes": {
		"commands": [
			{
				"command": "raptor.openPanel",
				"title": "raptor: Open Chat Panel"
			}
		],
		"chatParticipants": [
			{
				"id": "raptor",
				"name": "raptor",
				"fullName": "raptor Agent",
				"description": "Agent orchestrator for skills, specialist agents, and flow execution.",
				"isSticky": true,
				"commands": [
					{
						"name": "help",
						"description": "Show help and available tools"
					},
					{
						"name": "skills",
						"description": "List loaded skills"
					},
					{
						"name": "agents",
						"description": "List loaded agents"
					},
					{
						"name": "agent",
						"description": "Inspect or run a request-scoped agent"
					},
					{
						"name": "flows",
						"description": "List loaded flows"
					},
					{
						"name": "flow",
						"description": "Run a deterministic flow: /flow <id> [--resume] [--memory] [--list]"
					},
					{
						"name": "models",
						"description": "List available providers and models"
					},
					{
						"name": "build-flow",
						"description": "Design and build an agent flow for this project (defaults inferred when omitted)"
					}
				]
			}
		],
		"configuration": {
			"title": "raptor",
			"properties": {
				"raptor.maxIterations": {
					"type": "number",
					"default": 150,
					"minimum": 1,
					"description": "Maximum iterations for the main agent loop per request."
				},
				"raptor.spawnAgentMaxIterations": {
					"type": "number",
					"default": 60,
					"minimum": 1,
					"description": "Maximum iterations for spawned sub-agents."
				},
				"raptor.model": {
					"type": "string",
					"default": "claude-sonnet-4.6",
					"description": "Preferred fallback model when no session-selected model is available."
				},
				"raptor.defaultProvider": {
					"type": "string",
					"default": "vscode",
					"enum": ["vscode", "claude-code", "codex", "opencode"],
					"description": "Default provider to use when no model is specified."
				},
				"raptor.providers.enabled": {
					"type": "object",
					"default": { "claude-code": false, "codex": false, "opencode": false },
					"description": "Enable/disable individual providers."
				},
				"raptor.provider.claude-code.command": {
					"type": "string",
					"default": "claude",
					"description": "Path or command to Claude Code CLI."
				},
				"raptor.provider.claude-code.defaultModel": {
					"type": "string",
					"default": "sonnet",
					"description": "Default model for Claude Code CLI."
				},
				"raptor.provider.codex.command": {
					"type": "string",
					"default": "codex",
					"description": "Path or command to Codex CLI."
				},
				"raptor.provider.codex.defaultModel": {
					"type": "string",
					"default": "gpt-5.3-codex",
					"description": "Default model for Codex CLI."
				},
				"raptor.provider.opencode.command": {
					"type": "string",
					"default": "opencode",
					"description": "Path or command to OpenCode CLI."
				},
				"raptor.provider.opencode.defaultModel": {
					"type": "string",
					"default": "default",
					"description": "Default model for OpenCode CLI."
				}
			}
		}
	},
	"dependencies": {
		"vsce": "^2.15.0",
		"yaml": "^2.9.0"
	},
	"__metadata": {
		"installedTimestamp": 1775461056055,
		"targetPlatform": "undefined",
		"size": 297653
	}
}
